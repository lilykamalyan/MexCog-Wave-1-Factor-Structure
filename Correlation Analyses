#FACTOR SCORE CORRELATIONS WITH AGE ----

# Define variables
vars <- c("ORIEN", "MEMORY", "LANG", "EXECFUNC", "VISUAL", "GCP")

# Helper function to plot factor vs age with correlation label
plot_with_corr <- function(df, yvar, ylab) {
  
  # correlation and n
  r_raw <- cor(df$age, df[[yvar]], use = "complete.obs")
  r_fmt <- sub("^0\\.", ".", formatC(r_raw, format = "f", digits = 2))
  r_fmt <- sub("^-0\\.", "-.", r_fmt)  # handle negative values
  
  n_val <- sum(!is.na(df$age) & !is.na(df[[yvar]]))
  
  # stacked APA label
  label_text <- paste0(
    "atop(italic(r) == ", r_fmt,
    ", italic(n) == ", n_val, ")"
  )
  
  ggplot(df, aes(x = age, y = .data[[yvar]])) +
    geom_point(color = "gray20", alpha = 0.7) +
    geom_smooth(method = "lm", se = FALSE, color = "black", size = 1.5) +
    labs(title = ylab, x = "Age", y = NULL) +
    
    annotate("text", x = Inf, y = Inf, label = label_text,
             hjust = 1.1, vjust = 1.0, size = 10,
             color = "black", parse = TRUE) +
    
    theme_minimal(base_size = 14) +
    theme(
      plot.title = element_text(size = 30, face = "bold"),
      axis.title.y = element_blank(),
      axis.text = element_text(size = 18, color = "black"),
      panel.grid.major.x = element_blank(),
      panel.grid.minor.x = element_blank(),
      panel.grid.minor.y = element_blank(), 
      axis.line = element_line(color = "black", linewidth = 0.8)
    )
}

## Create plots for each factor ----
orien_age    <- plot_with_corr(data, "ORIEN",    "Orientation")
memory_age   <- plot_with_corr(data, "MEMORY",   "Memory")
lang_age     <- plot_with_corr(data, "LANG",     "Language")
execfunc_age <- plot_with_corr(data, "EXECFUNC", "Executive Function")
visual_age   <- plot_with_corr(data, "VISUAL",   "Visual")
gcp_age      <- plot_with_corr(data, "GCP",      "Global Cognitive Performance")


#show plots
orien_age
memory_age
lang_age
execfunc_age
visual_age
gcp_age



#FACTOR SCORE CORRELATIONS WITH EDUCATION ----

plot_with_corr <- function(df, yvar, ylab) {
  r_val <- cor(df$yrschool, df[[yvar]], use = "complete.obs")
  r_label <- paste0("italic(r) == ", round(r_val, 2))
  
  ggplot(df, aes(x = yrschool, y = .data[[yvar]])) +
    geom_point(color = "darkgray", alpha = 0.7) +
    geom_smooth(method = "lm", se = FALSE, color = "black", size = 1.5) + 
    scale_x_continuous(breaks = seq(min(df$yrschool, na.rm = TRUE), 
                                    max(df$yrschool, na.rm = TRUE), 1)) +
    labs(title = ylab, x = "Years of Schooling", y = NULL) +
    annotate("text", x = Inf, y = -Inf, label = r_label,
             parse = TRUE,
             hjust = 1.1, vjust = -0.5, size = 10, color = "black") +
    theme_minimal(base_size = 14) +
    theme(
      plot.title = element_text(size = 30, face = "bold"), 
      axis.title.y = element_blank(),
      panel.grid.major.x = element_blank(),
      panel.grid.minor.x = element_blank(),
      panel.grid.minor.y = element_blank(), 
      axis.line = element_line(color = "black", linewidth = 0.8)
    )
}


