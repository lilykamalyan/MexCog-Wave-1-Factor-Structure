plot_with_knots_edu <- function(df, yvar, ylab) {
  # correlation
  r_val <- cor(df$yrschool, df[[yvar]], use = "complete.obs")
  
  # sample size
  n_val <- sum(complete.cases(df$yrschool, df[[yvar]]))
  
  # combined label (stacked, both italicized)
  label_text <- paste0(
    "atop(italic(r) == ", round(r_val, 2),
    ", italic(n) == ", n_val, ")"
  )
  
  knots <- c(1, 6, 10)
  
  ggplot(df, aes(x = yrschool, y = .data[[yvar]])) +
    geom_point(color = "gray20", alpha = 0.4) +
    geom_smooth(
      method = "lm",
      formula = y ~ splines::ns(x, knots = knots),
      se = TRUE, color = "black", linewidth = 1.2
    ) +
    geom_vline(xintercept = knots, color = "black",
               linetype = "dashed", size = 1.5) +
    scale_x_continuous(
      breaks = seq(min(df$yrschool, na.rm = TRUE),
                   max(df$yrschool, na.rm = TRUE), 1)
    ) +
    labs(title = ylab, x = "Years of Schooling", y = NULL) +
    
    annotate(
      "text",
      x = Inf, y = -Inf,
      label = label_text,
      parse = TRUE,
      hjust = 1.05,   # slightly inside right edge
      vjust = -1.2,   # pushes it UP from bottom
      size = 10,
      color = "black"
    ) +
    
    theme_minimal(base_size = 14) +
    theme(
      plot.title = element_text(size = 30, face = "bold"),
      axis.title.y = element_blank(),
      axis.text = element_text(size = 18, color = "black"),
      panel.grid.major.x = element_blank(),
      panel.grid.minor.x = element_blank(),
      panel.grid.minor.y = element_blank(), 
      axis.line = element_line(color = "black", linewidth = 0.8)
    )
}

