##within factor scores ----

# your variables
vars <- c("ORIEN", "MEMORY", "LANG", "EXECFUNC", "VISUAL", "GCP")

# make combinations
combos <- t(combn(vars, 2))   # each row: c(var1, var2)

# function to compute cor + CI for a pair
cor_pair <- function(df, v1, v2, method = "pearson", conf.level = 0.95, digits = 3) {
  tmp <- df %>% select(all_of(c(v1, v2))) %>% filter(complete.cases(.))
  n <- nrow(tmp)
  if (n >= 3) {
    ct <- tryCatch(
      cor.test(tmp[[1]], tmp[[2]], method = method, conf.level = conf.level),
      error = function(e) NULL
    )
    if (!is.null(ct)) {
      r <- as.numeric(ct$estimate)
      ci <- ct$conf.int
      p <- ct$p.value
    } else {
      r <- NA_real_; ci <- c(NA_real_, NA_real_); p <- NA_real_
    }
  } else {
    r <- NA_real_; ci <- c(NA_real_, NA_real_); p <- NA_real_
  }
  tibble(
    var1 = v1,
    var2 = v2,
    r = round(r, digits),
    lower95 = round(ci[1], digits),
    upper95 = round(ci[2], digits),
    p = signif(p, 3),
    n = n,
    r_ci = ifelse(is.na(r), NA_character_,
                  sprintf("%0.*f (%0.*f, %0.*f)", digits, r, digits, ci[1], digits, ci[2]))
  )
}

# compute for all pairs and bind into one tibble
cor_tbl <- purrr::pmap_dfr(
  list(v1 = combos[,1], v2 = combos[,2]),
  ~ cor_pair(data, ..1, ..2, method = "pearson", conf.level = 0.95, digits = 3)
)

# view result
cor_tbl


