##orientation ----

orientation_data_long <- data %>%
  dplyr::select(
    id,
    day,
    month,
    year,
    wkday,
    country,
    state
  ) %>%
  dplyr::mutate(dplyr::across(c(day, month, year, wkday, country, state), as.numeric)) %>%
  labelled::remove_labels() %>%
  labelled::remove_attributes("display_width")

orientation_model_long <- mplusObject(
  
  MODEL = "
orien BY
day
month
year
wkday
country
state;
",
  
  usevariables = colnames(orientation_data_long),
  
  VARIABLE = "
IDVARIABLE = id;
MISSING ARE ALL (-999);
CATEGORICAL = day month year wkday country state;
",
  
  ANALYSIS = "
ESTIMATOR = WLSMV;
",
  
  OUTPUT = "
SAMPSTAT
STANDARDIZED
MODINDICES(3.84);
",
  
  rdata = orientation_data_long
)

orientation_final_long <- mplusModeler(
  orientation_model_long,
  modelout = "orientation_final_long.inp",
  run = TRUE
)

orientation_final_long <- readModels("orientation_final_long.out")
orientation_final_long

orientation_final_long$output


