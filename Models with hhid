#OVERALL SAMPLE - FINAL MODELS - WITH CLUSTER ID ----

data <- read.table(
  "C:/Users/lk2681.MC/R Files/mexcog2016_forcfa_040726_hhid_USE.dat",
  header = FALSE,
  na.strings = "-999"
)

colnames(data) <- c("id", "hhid", "age", "sex", "locality", "yrschool",
                    "cogtype", "animals", "day", "month", "year", 
                    "wkday", "time", "where", "store", "country", 
                    "state", "mmseimm", "ceradimm", "braveimm", 
                    "lmimm", "mmsedel", "ceraddel", "bravedel", 
                    "lmdelay", "ceradrec", "figdel", "visscan",
                    "bkwdcnt", "thrstep", "reading", "writing", "twostep",
                    "shoe", "pencil", "elbow", "bridge", "hammer", "scissors",
                    "mmserep", "onefig", "fourfig", "serthr", "sersev",
                    "symdig", "similar", "gonogo", "urbrur")

ncol(data)      # should be 48
colnames(data)  # confirm order
summary(data)

##orientation ----

orientation_data_hhid <- data %>%
  dplyr::select(
    id, hhid,
    day, month, year, wkday, country, state
  ) %>%
  dplyr::mutate(dplyr::across(c(day, month, year, wkday, country, state), as.numeric)) %>%
  labelled::remove_labels() %>%
  labelled::remove_attributes("display_width")

orientation_model_hhid <- mplusObject(
  
  MODEL = "
orien BY
day
month
year
wkday
country
state;
",

  usevariables = colnames(orientation_data_hhid),
  
  VARIABLE = "
IDVARIABLE = id;
CLUSTER = hhid;
MISSING ARE ALL (-999);
CATEGORICAL = day month year wkday country state;
",
  
  ANALYSIS = "
ESTIMATOR = WLSMV;
TYPE = COMPLEX;
",
  
  OUTPUT = "
SAMPSTAT
STANDARDIZED
MODINDICES(3.84);
",
  
  rdata = orientation_data_hhid
)

orientation_final_hhid <- mplusModeler(
  orientation_model_hhid,
  modelout = "orientation_final_hhid.inp",
  run = TRUE
)

orientation_final_hhid <- readModels("orientation_final_hhid.out")
orientation_final_hhid

orientation_final_hhid$output


