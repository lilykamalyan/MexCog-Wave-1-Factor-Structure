#BIFACTOR ASK FOR SVALUES ----

##orientation ----

orientation_data <- data %>%
  dplyr::select(
    id,
    day,
    month,
    year,
    wkday,
    country,
    state
  ) %>%
  dplyr::mutate(dplyr::across(c(day, month, year, wkday, country, state), as.numeric)) %>%
  labelled::remove_labels() %>%
  labelled::remove_attributes("display_width")

orientation_svalues_model <- mplusObject(
  
  MODEL = "
orien BY day* month wkday year country state;
orien@1;
dm BY month@1;
dm BY day@1;
dm WITH orien@0;
sc BY state@1;
sc BY country@1;
sc WITH orien@0;
sc WITH dm@0;
",
  
  usevariables = colnames(orientation_data),
  
  VARIABLE = "
IDVARIABLE = id;
MISSING ARE ALL (-999);
CATEGORICAL = day month wkday year country state;
",
  
  ANALYSIS = "
ESTIMATOR = MLR;
LINK = PROBIT;
",
  
  OUTPUT = "
SAMPSTAT
STANDARDIZED
MODINDICES(3.84)
SVALUES;
",
  
  rdata = orientation_data
)

orientation_svalues <- mplusModeler(
  orientation_svalues_model,
  modelout = "orientation_svalues.inp",
  run = TRUE
)

orientation_svalues <- readModels("orientation_svalues.out")

#show output
orientation_svalues$output

# view svalues
output_lines <- orientation_svalues$output
svalues_start <- grep("STARTING VALUES", output_lines)
output_lines[svalues_start:length(output_lines)]


