##orientation ----

orientation_data <- data %>%
  dplyr::select(
    id,
    day,
    month,
    year,
    wkday,
    country,
    state
  ) %>%
  dplyr::mutate(dplyr::across(c(day, month, year, wkday, country, state), as.numeric)) %>%
  labelled::remove_labels() %>%
  labelled::remove_attributes("display_width")

orientation_model <- mplusObject(
  
  MODEL = "
orien BY
day
month
year
wkday
country
state;
",
  
  usevariables = colnames(orientation_data),
  
  VARIABLE = "
IDVARIABLE = id;
MISSING ARE ALL (-999);
CATEGORICAL = day month year wkday country state;
",
  
  ANALYSIS = "
ESTIMATOR = WLSMV;
",
  
  OUTPUT = "
SAMPSTAT
STANDARDIZED
MODINDICES(3.84);
",
  
  rdata = orientation_data
)

orientation_final <- mplusModeler(
  orientation_model,
  modelout = "orientation_final.inp",
  run = TRUE
)

orientation_final <- readModels("orientation_final.out")
orientation_final

orientation_final$output


