##2nd order model GCP ----

gcp_data <- data %>%
  dplyr::select(
    id,
    day, month, year, wkday, country, state,
    mmseimm, ceradimm, braveimm, lmimm, mmsedel, ceraddel, bravedel, lmdelay, ceradrec, figdel,
    animals, shoe, pencil, bridge, hammer, scissors, mmserep, reading, writing, twostep, thrstep,
    visscan, bkwdcnt, symdig, similar, gonogo, serthr, onefig, fourfig
  ) %>%
  dplyr::mutate(dplyr::across(
    c(day, month, year, wkday, country, state,
      mmseimm, mmsedel,
      shoe, pencil, bridge, hammer, scissors,
      mmserep, reading, writing, twostep, thrstep,
      onefig), as.numeric
  )) %>%
  labelled::remove_labels() %>%
  labelled::remove_attributes("display_width")

gcp_model <- mplusObject(
  
  MODEL = "
orien BY day month year wkday country state;

memory BY mmseimm ceradimm braveimm lmimm mmsedel ceraddel
       bravedel lmdelay ceradrec figdel;

lang BY animals shoe pencil scissors bridge hammer mmserep
      reading writing twostep thrstep;

execfunc BY visscan bkwdcnt symdig similar gonogo serthr;

visual BY fourfig onefig;

gcp BY orien memory lang execfunc visual;

mmseimm WITH mmsedel;
ceradimm WITH ceraddel;
ceradimm WITH ceradrec;
ceraddel WITH ceradrec;
braveimm WITH bravedel;
lmimm WITH lmdelay;

pencil WITH shoe;
hammer WITH bridge;

visscan WITH symdig;
serthr WITH bkwdcnt;

fourfig WITH figdel;
symdig WITH reading;
symdig WITH writing;
visscan WITH reading;
visscan WITH reading;
",
  
  usevariables = colnames(gcp_data),
  
  VARIABLE = "
IDVARIABLE = id;
MISSING ARE ALL (-999);

USEVARIABLES ARE day month year wkday country state
                 mmseimm ceradimm braveimm lmimm mmsedel
                 ceraddel bravedel lmdelay ceradrec figdel
                 animals shoe pencil bridge hammer scissors
                 mmserep reading writing twostep thrstep
                 visscan bkwdcnt symdig similar gonogo
                 serthr onefig fourfig;

CATEGORICAL = day month year wkday country state
              mmseimm mmsedel
              shoe pencil bridge hammer scissors
              mmserep reading writing twostep thrstep
              serthr onefig similar;
",
  
  ANALYSIS = "
ESTIMATOR = WLSMV;
PARAMETERIZATION = THETA;
",
  
  OUTPUT = "
SAMPSTAT
STANDARDIZED
MODINDICES(3.84)
TECH4;
",
  
  SAVEDATA = "
FILE IS gcp_scores.dat;
SAVE = FSCORES;
",
  
  rdata = gcp_data
)

gcp_final <- mplusModeler(
  gcp_model,
  modelout = "gcp_final.inp",
  run = TRUE
)

gcp_final <- readModels("gcp_final.out")
gcp_final
gcp_final$output



